{
  "id": "record-and-replay",
  "title": "Record & Replay",
  "description": "Opt-in Linux demo-to-skill recording workflow powered by codex-record-replay-linux.",
  "defaultEnabled": false,
  "entrypoints": {
    "patchDescriptors": "./patch.js",
    "stageHook": "./stage.sh",
    "cleanupHook": "./cleanup.sh"
  },
  "runtimeHooks": {
    "coldStart": {
      "source": "chronicle-cold-start.sh",
      "name": "chronicle-cold-start.sh",
      "mode": "0755"
    }
  }
}
